{
  "name": "create-mn-app",
  "version": "0.3.23",
  "description": "Create Midnight Network applications with zero configuration",
  "main": "dist/index.js",
  "bin": {
    "create-mn-app": "./bin/create-midnight-app.js"
  },
  "files": [
    "bin",
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "npm run build && node dist/test.js",
    "test-local": "npm run build && npm link && npx create-mn-app test-app",
    "clean": "rm -rf dist test-app",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "midnight",
    "blockchain",
    "zero-knowledge",
    "privacy",
    "scaffold",
    "cli",
    "create-app",
    "zkp",
    "dapp",
    "web3",
    "smart-contracts",
    "typescript"
  ],
  "author": "Idris Olubisi",
  "contributors": [
    "Midnight Network"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.3",
    "fastest-levenshtein": "^1.0.16",
    "fs-extra": "^11.1.1",
    "mustache": "^4.2.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2",
    "semver": "^7.5.4",
    "update-notifier": "^7.3.1",
    "validate-npm-package-name": "^5.0.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.2",
    "@types/fs-extra": "^11.0.1",
    "@types/mustache": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "@types/update-notifier": "^6.0.8",
    "@types/validate-npm-package-name": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/midnightntwrk/create-mn-app.git"
  },
  "homepage": "https://github.com/midnightntwrk/create-mn-app#readme",
  "bugs": {
    "url": "https://github.com/midnightntwrk/create-mn-app/issues"
  }
}
